# --- Required settings even when working locally. ---

# OpenAI API Config
OPENAI_MODEL_ID=gpt-4o-mini
OPENAI_API_KEY=str

# Huggingface API Config
HUGGINGFACE_ACCESS_TOKEN=str

# Knowledge assistant models and storage
EMBEDDING_MODEL_ID=intfloat/multilingual-e5-small
VECTOR_STORE_PATH=data/indexes
QWEN_MODEL_ID=Qwen/Qwen3.5-2B
MLX_MODEL_CACHE_PATH=data/models

# Comet ML (during training and inference) 
COMET_API_KEY=str

# --- Required settings when deploying the code. ---
# --- Otherwise, default values work fine. ---

# MongoDB database
DATABASE_HOST="mongodb://llm_engineering:llm_engineering@127.0.0.1:27017"

# Qdrant vector database
USE_QDRANT_CLOUD=false
QDRANT_CLOUD_URL=str
QDRANT_APIKEY=str

# AWS Authentication
AWS_ARN_ROLE=str
AWS_REGION=eu-central-1
AWS_ACCESS_KEY=str
AWS_SECRET_KEY=str
